FROM ghcr.io/zedbiz44/openclaw-base:latest

ARG DOCKER_CLI_VERSION=29.5.2

USER root
RUN apt-get update -qq \
    && apt-get install -y -q --no-install-recommends openssh-client ca-certificates curl tar \
    && curl -fsSL "https://download.docker.com/linux/static/stable/x86_64/docker-${DOCKER_CLI_VERSION}.tgz" \
      | tar -xz -C /tmp --strip-components=1 docker/docker \
    && mv /tmp/docker /usr/local/bin/docker \
    && chmod 0755 /usr/local/bin/docker \
    && rm -rf /var/lib/apt/lists/*
USER node
